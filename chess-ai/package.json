{
  "name": "chess-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "build:exe": "SET VITE_APP_MODE=EXE&& vite build",
    "obfuscate": "javascript-obfuscator dist/assets --output dist/assets --compact true --self-defending true --string-array true --string-array-rotate true --string-array-shuffle true --string-array-threshold 0.75",
    "package": "npm run build:exe && npm run obfuscate && electron-packager . NeuralChess --platform=win32 --arch=x64 --out=release-builds --overwrite --asar",
    "test": "node --test \"tests/*.test.js\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^31.7.7",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "javascript-obfuscator": "^4.1.1",
    "vite": "^8.0.1"
  }
}
