{
  "name": "neural-chess",
  "productName": "Neural Chess",
  "description": "Play chess against large language models. An LLM-vs-human chess lab built with React, Vite, and Electron.",
  "author": "Charg",
  "license": "MIT",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "build:exe": "cross-env VITE_APP_MODE=EXE vite build",
    "package": "npm run build:exe && electron-builder --win",
    "package:dir": "npm run build:exe && electron-builder --win --dir",
    "release": "npm run build:exe && electron-builder --win --publish never",
    "test": "node --test \"tests/*.test.js\"",
    "test:e2e": "npm run build && playwright test",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "electron-updater": "^6.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.neuralchess.desktop",
    "productName": "Neural Chess",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**",
      "electron/**",
      "src/services/llmCore.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "NeuralChess-Setup-${version}.${ext}"
    }
  }
}
